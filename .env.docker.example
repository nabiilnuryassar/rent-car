# =============================================================================
# Rent Car — Production Docker Environment
#
# Copy this file to `.env.docker` before running `docker compose up`.
#   cp .env.docker.example .env.docker
#
# REQUIRED: replace APP_KEY and DB_PASSWORD before deploying.
# =============================================================================

# -----------------------------
# App
# -----------------------------
APP_NAME="Rent Car"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://rentcar.example.com
APP_PORT=8080

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

# -----------------------------
# Database (PostgreSQL)
# -----------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=rentcar
DB_USERNAME=rentcar
DB_PASSWORD=please_change_me

# -----------------------------
# Redis (cache + queue + session)
# -----------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=phpredis

# -----------------------------
# Caching / Sessions / Queue
# -----------------------------
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# -----------------------------
# Filesystem
# -----------------------------
FILESYSTEM_DISK=public

# If using S3-compatible storage:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_ENDPOINT=

# -----------------------------
# Mail
# -----------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@rentcar.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------
# Container boot flags (read by docker/entrypoint.sh)
# -----------------------------
RUN_MIGRATIONS=true
RUN_SEEDERS=false
LINK_STORAGE=true

# -----------------------------
# Trusted proxies (set when behind CloudFlare / ALB / Traefik)
# -----------------------------
TRUSTED_PROXIES=*

# -----------------------------
# Cloudflare Tunnel
#
# Buat tunnel di https://one.dash.cloudflare.com/ → Networks → Tunnels
# Pilih connector type "Docker", lalu copy token yang muncul ke sini.
# Di tab Public Hostname, arahkan ke http://app:8080
# -----------------------------
CLOUDFLARE_TUNNEL_TOKEN=
