@startuml
title Use Case Diagram (AS-BUILT) - Sistem Informasi Rental Kendaraan
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Pelanggan\n(Customer)" as Customer
actor "Pelanggan Lama\n(Loyal Customer)" as LoyalCustomer
actor "Admin" as Admin
actor "Kasir" as Cashier
actor "Supir\n(Driver)" as Driver

rectangle "Rent Car Platform (Web)" {
  ' === AUTH ===
  usecase "UC-01\nRegistrasi / Login" as UC01
  usecase "UC-26\nPilih Role Dashboard\n(role-based redirect)" as UC26 <<extension>>

  ' === CATALOG & BOOKING ===
  usecase "UC-02\nBrowse Katalog\n& Lihat Detail" as UC02
  usecase "UC-03\nBuat Order Sewa\nKendaraan" as UC03
  usecase "UC-04\nPilih Durasi, Unit,\nWilayah, Lokasi" as UC04
  usecase "UC-05\nHitung Tarif\nOtomatis" as UC05
  usecase "UC-06\nPilih Supir" as UC06
  usecase "UC-07\nFree Upgrade\n(manual accept/reject)" as UC07
  usecase "UC-08\nPesan Layanan\nAntar-Jemput" as UC08

  ' === PAYMENT ===
  usecase "UC-09\nUpload Bukti\nTransfer" as UC09
  usecase "UC-10\nInput Pembayaran\nTunai" as UC10
  usecase "UC-11\nVerifikasi\nTransfer" as UC11
  usecase "UC-12\nGenerate Kwitansi\n(digital, browser print)" as UC12

  ' === MASTER DATA ===
  usecase "UC-13\nKelola Kendaraan\n& Kategori" as UC13
  usecase "UC-14\nKelola Pricing Rule\n& Overtime Penalty" as UC14
  usecase "UC-15\nKelola Data\nSupir" as UC15
  usecase "UC-19\nKelola Tarif\nShuttle" as UC19

  ' === ORDER LIFECYCLE ===
  usecase "UC-16\nDispatch Order\n(payment-locked)" as UC16
  usecase "UC-17\nCatat Return\n& Aktual Time" as UC17
  usecase "UC-18\nHitung Overtime\n(kelipatan jam)" as UC18
  usecase "UC-20\nComplete Order" as UC20

  ' === DASHBOARD & REPORT ===
  usecase "UC-21\nLihat Dashboard\nOperasional" as UC21
  usecase "UC-22\nGenerate Laporan\nTransaksi & Revenue" as UC22

  ' === AUDIT ===
  usecase "UC-23\nView Audit Log\n(internal)" as UC23

  ' === RECEIPTS ===
  usecase "UC-24\nLihat Receipt\n(customer + staff)" as UC24

  ' === ORDER HISTORY ===
  usecase "UC-25\nLihat Riwayat\nOrder" as UC25
}

' === CUSTOMER FLOWS ===
Customer --> UC01
Customer --> UC02
Customer --> UC03
Customer --> UC08
Customer --> UC09
Customer --> UC24
Customer --> UC25

LoyalCustomer --|> Customer
LoyalCustomer --> UC06

' === ADMIN FLOWS ===
Admin --> UC11
Admin --> UC13
Admin --> UC14
Admin --> UC15
Admin --> UC19
Admin --> UC16
Admin --> UC17
Admin --> UC20
Admin --> UC21
Admin --> UC22
Admin --> UC23

' === KASIR FLOWS ===
Cashier --> UC10
Cashier --> UC11
Cashier --> UC24

' === DRIVER FLOWS (limited) ===
Driver --> UC01

' === INCLUDES / EXTENDS ===
UC01 .> UC26 : <<include>>
UC03 .> UC04 : <<include>>
UC03 .> UC05 : <<include>>
UC03 .> UC06 : <<extend>>\n[loyal customer]
UC03 .> UC07 : <<extend>>\n[stock empty]
UC08 .> UC05 : <<include>>
UC09 .> UC11 : <<include>>
UC10 .> UC12 : <<include>>
UC11 .> UC12 : <<include>>
UC17 .> UC18 : <<include>>
UC20 .> UC17 : <<include>>

note right of UC07
  NOTE: Auto-trigger saat stock empty
  belum diimplementasi (v1.1 roadmap).
  Saat ini UpgradeOffer dibuat manual
  oleh admin/sistem eksternal.
end note

note right of UC16
  Payment lock enforced by
  OrderStatusService::assertCanDispatch()
  Requires paid payment + ReadyToDispatch status
end note

note right of UC23
  Audit log via AuditLogger service.
  Captures: payment verify, dispatch,
  return, complete actions.
end note

@enduml
